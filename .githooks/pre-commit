#!/usr/bin/env sh
# K4 Remote pre-commit hook: formatting + lints must be clean before a commit.
# Enable once per clone with:  git config core.hooksPath .githooks
set -eu

echo "[pre-commit] cargo fmt --all -- --check"
cargo fmt --all -- --check

echo "[pre-commit] cargo clippy --all-targets -- -D warnings"
cargo clippy --all-targets -- -D warnings

echo "[pre-commit] OK"
